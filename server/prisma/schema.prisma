generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────
// Enums
// ──────────────────────────────
enum Role {
  USER
  ADMIN
}

enum Category {
  TOP
  BOTTOM
  OUTER
  DRESS
  SHOES
  BAG
  ACCESSORY
}

enum ProductStatus {
  ACTIVE
  SOLDOUT
  HIDDEN
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELLED
}

// ──────────────────────────────
// 회원
// ──────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ──────────────────────────────
// 상품
// ──────────────────────────────
model Product {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  price       Int
  salePrice   Int?
  category    Category
  status      ProductStatus  @default(ACTIVE)
  images      ProductImage[]
  options     ProductOption[]
  orderItems  OrderItem[]
  isDeleted   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductOption {
  id        String  @id @default(cuid())
  color     String
  size      String
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
  @@map("product_options")
}

// ──────────────────────────────
// 주문
// ──────────────────────────────
model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payment        Payment?
  status         OrderStatus @default(PENDING)
  totalAmount    Int
  shippingFee    Int         @default(0)
  recipientName  String
  recipientPhone String
  zipCode        String
  address        String
  addressDetail  String
  deliveryMemo   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  optionColor String
  optionSize  String
  quantity    Int
  price       Int

  @@map("order_items")
}

// ──────────────────────────────
// 결제
// ──────────────────────────────
model Payment {
  id         String        @id @default(cuid())
  orderId    String        @unique
  order      Order         @relation(fields: [orderId], references: [id])
  paymentKey String        @unique
  method     String
  amount     Int
  status     PaymentStatus @default(PENDING)
  approvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@map("payments")
}
